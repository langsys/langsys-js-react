{
    "name": "langsys-js-react",
    "version": "0.1.0",
    "description": "React binding for the Langsys translation SDK — realtime continuous translations with automatic token discovery, delivered as hooks and a <Translate> component.",
    "author": "Langsys",
    "license": "MIT",
    "homepage": "https://github.com/langsys/langsys-js-react",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/langsys/langsys-js-react.git"
    },
    "bugs": {
        "url": "https://github.com/langsys/langsys-js-react/issues"
    },
    "engines": {
        "node": ">=18"
    },
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "README-SSR.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "dev": "vite",
        "build": "tsup",
        "build:watch": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "prepublishOnly": "npm run build",
        "release": "./_dev_/publish.sh"
    },
    "keywords": [
        "i18n",
        "l10n",
        "react",
        "react-hooks",
        "language",
        "localization",
        "internationalization",
        "translation",
        "langsys",
        "sdk"
    ],
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "langsys-js-typescript": "file:../langsys-js-typescript"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "prettier": "^3.3.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tsup": "^8.4.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.0.0",
        "vite": "^6.0.0",
        "vitest": "^4.1.7"
    }
}
